{
  "name": "class-companion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/check-env.mjs && npm run check:nullable-upserts && npm run audit:answer-position",
    "build": "prisma generate && next build",
    "deploy": "prisma migrate deploy && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "analyze": "ANALYZE=true next build",
    "analyze:server": "BUNDLE_ANALYZE=server ANALYZE=true next build",
    "analyze:browser": "BUNDLE_ANALYZE=browser ANALYZE=true next build",
    "test:gamification": "node --import tsx scripts/tests/gamification-helpers.test.ts",
    "test:activity-submit": "node --import tsx scripts/tests/activity-submit-assignmentid.test.ts",
    "test:exercise-answer-normalization": "node --import tsx scripts/tests/exercise-answer-normalization.test.ts",
    "test:activity-submit:contract": "node --import tsx --test scripts/tests/activity-submit-contract.test.ts",
    "test:activity-progress:merge": "node --import tsx --test scripts/tests/activity-progress-merge.test.ts",
    "test:activity-progress:points": "node --import tsx --test scripts/tests/activity-progress-points-gating.test.ts",
    "test:assignments-featured": "node --import tsx --test scripts/tests/assignments-featured-derivation.test.ts",
    "test:classes-join": "node --import tsx --test scripts/tests/classes-join-contract.test.ts",
    "test:submission-points-claim": "node --import tsx --test scripts/tests/submission-points-claim.test.ts",
    "test:sanitize": "node --import tsx --test scripts/tests/sanitize-security.test.ts",
    "test:validators-env": "node --import tsx --test scripts/tests/validators-env-boundary.test.ts",
    "test:critical": "npm run test:gamification && npm run test:activity-submit && npm run test:exercise-answer-normalization && npm run test:activity-submit:contract && npm run test:activity-progress:merge && npm run test:activity-progress:points && npm run test:assignments-featured && npm run test:classes-join && npm run test:submission-points-claim && npm run test:sanitize && npm run test:validators-env",
    "test:vitest": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test tests/e2e/mobile-pwa-smoke.spec.ts",
    "test:e2e:smoke": "playwright test tests/e2e/mobile-pwa-smoke.spec.ts tests/e2e/auth-flow.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install --with-deps",
    "lint": "eslint",
    "audit:answer-position": "node scripts/checks/audit-answer-position-bias.js",
    "audit:answer-position:update-baseline": "node scripts/checks/audit-answer-position-bias.js --update-baseline",
    "check:nullable-upserts": "node scripts/checks/check-null-assignment-upserts.mjs",
    "typecheck": "tsc --noEmit",
    "db:seed": "npm run db:seed:grammar",
    "db:seed:grammar": "npx tsx prisma/seed-grammar-only.ts && node prisma/seed.js",
    "db:seed:minimal-pairs": "npx tsx prisma/seed-minimal-pairs.ts",
    "db:seed:users": "npx tsx prisma/seed-users-only.ts",
    "db:seed:vocab": "node scripts/migrations/update-all-vocab.js && node scripts/content/create-vocab-games.js",
    "db:seed:weekly-vocab": "node scripts/vocab/seed-weekly-vocab.js",
    "db:seed:quizzes": "npm run import:countable-uncountable && npm run import:verb-quizzes",
    "db:seed:full": "npx tsx prisma/seed-full-reset.ts && npx tsx prisma/seed-users-only.ts && npx tsx prisma/seed-grammar-only.ts && node prisma/seed.js && npm run db:seed:vocab && npm run db:seed:quizzes",
    "db:backup:safe": "npx tsx scripts/db/backup-database-safe.ts",
    "db:backup:check": "npx tsx scripts/checks/check-backups.ts",
    "db:migrate": "prisma migrate deploy",
    "import:simple-tenses": "node scripts/import/import-simple-tenses.mjs",
    "import:countable-uncountable": "npx tsx scripts/import/import-countable-uncountable-game.ts",
    "import:verb-quizzes": "npx tsx scripts/import/import-verb-quizzes.ts",
    "import:time-indicators": "npx tsx scripts/import/import-time-indicators-game.ts",
    "delete:verb-quizzes": "npx tsx scripts/import/delete-verb-quizzes.ts",
    "audio:minimal-pairs": "npx tsx scripts/content/generate-minimal-pairs-audio.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@sentry/nextjs": "^10.42.0",
    "@vercel/analytics": "^1.6.1",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.23.25",
    "lucide-react": "^0.556.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "node-html-parser": "^6.1.13",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "^2.15.0",
    "sanitize-html": "^2.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
