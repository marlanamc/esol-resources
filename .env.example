# Database
POSTGRES_URL="postgresql://user:password@localhost:5432/esol_db"

# NextAuth Configuration
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# For production (Vercel), set these in your Vercel project settings:
# POSTGRES_URL - Your PostgreSQL database URL
# NEXTAUTH_SECRET - A secure random string (use: openssl rand -base64 32)
# NEXTAUTH_URL - Your production URL (e.g., https://your-app.vercel.app)

CRON_SECRET="your-vercel-cron-secret-here"

# Local account passwords
# Choose unique local-only passwords; these are required for seeded accounts and auto-created system test students.
DEV_SEED_ACCOUNT_PASSWORD="set-a-unique-local-seed-password"
TEST_STUDENT_DEFAULT_PASSWORD="set-a-unique-local-system-student-password"

# Optional: ElevenLabs TTS (for pronunciation/minimal-pairs audio generation scripts)
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"

# Optional: backup encryption key for scripts/db/backup-database-safe.ts
BACKUP_ENCRYPTION_KEY="a-long-random-secret-for-backup-encryption"

# Optional: performance query timing logs
# PERF_LOG_ENABLED defaults to true in production and false elsewhere
PERF_LOG_ENABLED="true"
# Warn threshold for query timing logs (milliseconds)
PERF_LOG_THRESHOLD_MS="300"
# Sampling rate from 0 to 1
PERF_LOG_SAMPLE_RATE="0.2"

# Optional: Sentry error tracking (only activates when DSN is set)
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="your-project"

# Optional: feature flag for client submission outbox queue + banner
# Set to "true" to enable offline queueing and outbox status UI
NEXT_PUBLIC_ENABLE_SUBMISSION_OUTBOX="false"
